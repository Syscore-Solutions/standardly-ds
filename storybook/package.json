{
  "name": "standardly-storybook",
  "private": true,
  "version": "0.0.0",
  "description": "Standardly Design System — pipeline proof: tokens.json → Storybook components",
  "type": "module",
  "scripts": {
    "build:tokens": "node build-tokens.mjs",
    "prestorybook": "npm run build:tokens",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run build:tokens",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "cal-sans": "^1.0.1",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.6.18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3",
    "@storybook/addon-a11y": "^8",
    "@storybook/addon-essentials": "^8",
    "@storybook/react": "^8",
    "@storybook/react-vite": "^8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^6.0.0"
  },
  "bin": {
    "storybook": "./node_modules/.bin/storybook"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}
